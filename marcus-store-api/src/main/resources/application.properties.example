
# CẤU HÌNH SERVER & ỨNG DỤNG
server.port=8080
spring.application.name=MarcusStore


# CẤU HÌNH KẾT NỐI SQL SERVER
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=MarcusStoreDB;encrypt=true;trustServerCertificate=true;
spring.datasource.username=sa
spring.datasource.password=your_password_here
spring.datasource.driver-class-name=com.microsoft.sqlserver.jdbc.SQLServerDriver

# Cấu hình Pool kết nối (HikariCP) để tối ưu hiệu năng chịu tải
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.max-lifetime=1200000

# CẤU HÌNH JPA / HIBERNATE
# 'validate' kiểm tra tính khớp nhau giữa Entity và DB
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.database-platform=org.hibernate.dialect.SQLServerDialect

# Hiển thị và định dạng câu lệnh SQL chạy ngầm
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.use_sql_comments=false
spring.jpa.open-in-view=false
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl

# CẤU HÌNH ĐỊNH DẠNG DỮ LIỆU JSON (JACKSON)
spring.jackson.time-zone=Asia/Ho_Chi_Minh
spring.jackson.date-format=yyyy-MM-dd HH:mm:ss

# CẤU HÌNH BẢO MẬT JWT (JSON WEB TOKEN)

# Chuỗi khóa bí mật dùng để ký token (Yêu cầu chuỗi Base64 ngẫu nhiên, dài, bảo mật)
marcusstore.app.jwtSecret=MarcusStoreSecretKey2026DATNSuperSecureKeyDoNotSharePleaseMakeItLongerThan64Chars
# Thời gian sống của Access Token (Ví dụ: 86400000 ms = 24 giờ)
marcusstore.app.jwtExpirationMs=86400000

# CẤU HÌNH UPLOAD FILE (MULTIPART) - BỔ SUNG
# Giới hạn dung lượng tối đa cho 1 file (VD: 5MB để tối ưu băng thông)
spring.servlet.multipart.max-file-size=5MB
# Giới hạn dung lượng tối đa cho 1 request chứa nhiều file
spring.servlet.multipart.max-request-size=20MB


